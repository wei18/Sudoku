    "leave.game.message" : {
      "comment" : "SDD-003 Epic 2 — Leave Game confirmation dialog: message body explaining that progress is auto-saved.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your progress is saved automatically when you're signed in to iCloud."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu progreso se guarda automáticamente cuando inicias sesión en iCloud."
