          }
        }
      }
    },
    "Notifications are turned off for Sudoku in Settings, so we can't tell you when the Daily is ready." : {
      "comment" : "#287 Settings Reminders entry — local-notification daily reminder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
