<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Sudoku</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <!--
      Encryption export compliance (Apple docs:
      https://developer.apple.com/documentation/security/complying-with-encryption-export-regulations).
      Declared `false` because Sudoku uses no proprietary encryption and only
      exempt uses of standard system encryption (HTTPS via URLSession, Keychain,
      App Transport Security). Setting this here lets TestFlight upload skip
      the "Export Compliance Information" question on every build.
    -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!--
      Google Mobile Ads SDK 13.x requires this key to be present at app launch
      (the SDK crashes early in `MobileAds.shared.start` if absent).
      v2.5.2 uses Google's universal TEST App ID so real-device verification
      cannot accidentally serve production creatives. v2.5.3 (user-owned, just
      before ASC submission) swaps to the production App ID; the per-ad-unit
      ID in `LiveAdMobBridge.swift` swaps as a paired flip.
      v2.5.3 swap: see docs/v2/v2.5-readiness.md §v2.5.3 for the production
      App ID + ad unit ID + paired-flip checklist.
    -->
    <key>GADApplicationIdentifier</key>
    <string>ca-app-pub-3940256099942544~1458002511</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.puzzle-games</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSGameKitFriendListUsageDescription</key>
    <string>Sudoku uses your friend list to show your friends’ best times on the daily leaderboard.</string>
    <!--
      Required by App Tracking Transparency. The AdMob / UMP consent flow
      at app launch calls `ATTrackingManager.requestTrackingAuthorization`
      (see `Packages/AppMonetizationKit/Sources/AdsAdMob/ATTPresenter.swift`).
      Without this key the OS terminates the process at TCC with:
      "This app has crashed because it attempted to access privacy-sensitive
       data without a usage description."
    -->
    <key>NSUserTrackingUsageDescription</key>
    <string>Sudoku uses this identifier to show ads relevant to your interests. You can decline and ads still work — just less tailored.</string>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
