// Apple Developer signing configuration — template.
//
// COPY this file to `Tuist/Signing.xcconfig` (gitignored) and fill in your
// 10-character Apple Developer team identifier. The real file must NEVER
// be committed.
//
// Find your team ID at https://developer.apple.com/account → Membership Details.
//
// On a fresh clone:
//   cp Tuist/Signing.xcconfig.example Tuist/Signing.xcconfig
//   # then edit Tuist/Signing.xcconfig and replace YOUR_TEAM_ID_HERE
//   mise exec -- tuist generate
//
// For CI (Xcode Cloud): no setup needed. Xcode Cloud auto-provides
// $CI_TEAM_ID (https://developer.apple.com/documentation/xcode/environment-variable-reference);
// ci_post_clone.sh writes this file from it before `tuist generate` runs.
// See foundations.md §7 for the full secrets posture.

DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE
