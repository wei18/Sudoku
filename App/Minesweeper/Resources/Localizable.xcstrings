    "iap.minesweeper.remove_ads.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove all in-app ads forever. Family Sharing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina todos los anuncios de la app para siempre. Compatible con En familia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリ内のすべての広告を永久に非表示にします。ファミリー共有対応。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱 내 모든 광고를 영구적으로 제거합니다. 가족 공유 지원."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "นำโฆษณาในแอปทั้งหมดออกถาวร รองรับการแชร์กันในครอบครัว"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "永久移除 App 内所有广告。支持“家人共享”。"
