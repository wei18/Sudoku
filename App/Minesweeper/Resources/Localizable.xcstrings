    "Generated puzzles will be re-derived next play. Saved games are not affected." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generated puzzles will be re-derived next play. Saved games are not affected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los puzles se regenerarán la próxima vez. Las partidas guardadas no se verán afectadas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "次回プレイ時にパズルが再生成されます。保存済みのゲームには影響しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다음 플레이 시 퍼즐이 다시 생성됩니다. 저장된 게임에는 영향이 없습니다."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปริศนาจะถูกสร้างใหม่ในการเล่นครั้งต่อไป เกมที่บันทึกไว้จะไม่ได้รับผลกระทบ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次游玩时将重新生成题目。已保存的进度不受影响。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下次遊玩時將重新產生題目。已存進度不受影響。"
          }
        }
      }
    },
