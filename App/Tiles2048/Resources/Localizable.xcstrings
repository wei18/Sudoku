    "Enable notifications in System Settings → Notifications → 2048 Tiles.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable notifications in System Settings → Notifications → 2048 Tiles."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請至「系統設定」→「通知」→「2048 Tiles」開啟通知。"
