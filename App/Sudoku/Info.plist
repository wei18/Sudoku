<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Sudoku</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>2.6.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <!--
      Encryption export compliance (Apple docs:
      https://developer.apple.com/documentation/security/complying-with-encryption-export-regulations).
      Declared `false` because Sudoku uses no proprietary encryption and only
      exempt uses of standard system encryption (HTTPS via URLSession, Keychain,
      App Transport Security). Setting this here lets TestFlight upload skip
      the "Export Compliance Information" question on every build.
    -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!--
      Google Mobile Ads SDK 13.x requires GADApplicationIdentifier at app
      launch (the SDK crashes early in `MobileAds.shared.start` if absent).
      Both values are substituted at build time from `Tuist/AdMob.xcconfig`
      (gitignored; .example template committed). XCC writes the xcconfig
      from per-workflow env vars in `ci_scripts/ci_post_clone.sh` so prod
      builds get production IDs and local/sandbox builds get Google's
      universal test IDs. Replaces the old in-source DEBUG-vs-Release
      fatalError gate in AppComposition/Live.swift (the smoke test in
      AppCompositionTests catches missing-key misconfig pre-archive).

      `GADBannerUnitID` is our own key (not Google-reserved) — the banner
      provider in `Live.swift` reads it via
      `Bundle.main.object(forInfoDictionaryKey: "GADBannerUnitID")`.
    -->
    <key>GADApplicationIdentifier</key>
    <string>$(ADMOB_APP_ID)</string>
    <key>GADBannerUnitID</key>
    <string>$(ADMOB_BANNER_UNIT_ID)</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.puzzle-games</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSGameKitFriendListUsageDescription</key>
    <string>Sudoku uses your friend list to show your friends’ best times on the daily leaderboard.</string>
    <!--
      Required by App Tracking Transparency. The AdMob / UMP consent flow
      at app launch calls `ATTrackingManager.requestTrackingAuthorization`
      (see `Packages/AppMonetizationKit/Sources/AdsAdMob/ATTPresenter.swift`).
      Without this key the OS terminates the process at TCC with:
      "This app has crashed because it attempted to access privacy-sensitive
       data without a usage description."
      This literal is the BASE/fallback only; the localized 7-locale strings
      live in `App/Sudoku/Resources/InfoPlist.xcstrings` (#371). Keep the two
      English values in sync.
    -->
    <key>NSUserTrackingUsageDescription</key>
    <string>Sudoku uses your device's advertising identifier to keep ads relevant — not to build a profile of you. Decline and ads still show, just less tailored; or remove ads entirely.</string>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
