#!/usr/bin/env bash
#MISE description="L10n completeness + SudokuAppCompositionTests fixture-sync gate: shipping catalogs (Sudoku + Minesweeper + Tiles2048) have 0 <TRANSLATE> placeholders and all 7 locales per key (#394); the Localizable + PrivacyInfo test fixtures stay byte-copies of shipping (#361 C)."
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
LOCALES="en zh-Hant zh-Hans ja ko es th"

fail=0

check_catalog() {
  local path="$1"
  local name="$2"
  if [ ! -f "$path" ]; then
    echo "ERROR [$name]: catalog not found at $path" >&2
    fail=1
    return
  fi

  # 1) No <TRANSLATE> placeholders.
  local n
  n="$(grep -c '<TRANSLATE>' "$path" || true)"
  if [ "$n" -ne 0 ]; then
    echo "FAIL [$name]: $n <TRANSLATE> placeholder(s) remain in $path" >&2
    fail=1
  fi

  # 2) Every translatable key carries all 7 locales (skip shouldTranslate=false).
  REPO_ROOT="$REPO_ROOT" python3 - "$path" "$name" $LOCALES <<'PY' || fail=1
import json, sys
path, name = sys.argv[1], sys.argv[2]
locales = set(sys.argv[3:])
d = json.load(open(path, encoding="utf-8"))
# 2a) Structural guard: string entries appended at the JSON root (outside
# "strings") are valid JSON but invisible to Xcode at runtime — the key
# renders raw in the UI. Caught live in PR #474; only allow the three
# top-level keys the xcstrings schema defines.
extra = sorted(set(d.keys()) - {"sourceLanguage", "strings", "version"})
if extra:
    print(f"FAIL [{name}]: keys outside the 'strings' object (Xcode will never "
          f"resolve them): {extra}", file=sys.stderr)
    sys.exit(1)
bad = []
for key, entry in d.get("strings", {}).items():
    if entry.get("shouldTranslate") is False:
        continue
    present = set(entry.get("localizations", {}).keys())
    missing = locales - present
    if missing:
        bad.append((key, sorted(missing)))
if bad:
    for key, miss in bad:
        print(f"FAIL [{name}]: key {key!r} missing locales {miss}", file=sys.stderr)
    sys.exit(1)
PY
}

check_catalog "$REPO_ROOT/App/Sudoku/Resources/Localizable.xcstrings" "Sudoku"
check_catalog "$REPO_ROOT/App/Minesweeper/Resources/Localizable.xcstrings" "Minesweeper"
check_catalog "$REPO_ROOT/App/Tiles2048/Resources/Localizable.xcstrings" "Tiles2048"

# 2.5) Shared-code dotted-key consistency (#594). A dotted-namespace localization
#    key (e.g. `leave.game.close`) referenced from a SHARED UI target — linked by
#    ALL three apps and resolving against `bundle: .main` — must exist in EVERY
#    app catalog, else it renders the raw key (caught live: Tiles2048's leave-game
#    dialog + close button announced `leave.game.*` in VoiceOver). The per-catalog
#    completeness check above can't see this: each catalog was "complete" for the
#    keys it HAD. Scoped to dotted keys (unambiguous l10n keys, no app-conditional
#    English-phrase false positives); "in >=1 catalog but not all" is the signal.
REPO_ROOT="$REPO_ROOT" python3 - <<'PY' || fail=1
import json, re, pathlib, sys, os
repo = pathlib.Path(os.environ["REPO_ROOT"])
shared_dirs = [
    "Packages/GameAppKit/Sources",
    "Packages/GameShellKit/Sources/GameShellUI",
    "Packages/SettingsKit/Sources/SettingsUI",
    "Packages/AppMonetizationKit/Sources/MonetizationUI",
]
# First string-literal arg of the common localized SwiftUI initializers /
# modifiers (excludes `verbatim:` and interpolated `\(...)` literals).
pat = re.compile(
    r'(?:Text|LocalizedStringKey|Label|Button|Toggle|Picker)\(\s*"([^"\\]+)"'
    r'|\.(?:navigationTitle|accessibilityLabel|accessibilityHint|accessibilityValue)'
    r'\(\s*(?:Text\(\s*)?"([^"\\]+)"'
)
DOTTED = re.compile(r'^[a-z][a-z0-9]*(?:\.[a-z0-9]+)+$')
ref = set()
for d in shared_dirs:
    p = repo / d
    if not p.exists():
        continue
    for f in p.rglob("*.swift"):
        for m in pat.finditer(f.read_text(encoding="utf-8")):
            k = m.group(1) or m.group(2)
            if k and DOTTED.match(k):
                ref.add(k)
apps = [
    ("Sudoku", "App/Sudoku/Resources/Localizable.xcstrings"),
    ("Minesweeper", "App/Minesweeper/Resources/Localizable.xcstrings"),
    ("Tiles2048", "App/Tiles2048/Resources/Localizable.xcstrings"),
]
cats = {n: set(json.load(open(repo / p, encoding="utf-8"))["strings"].keys())
        for n, p in apps}
bad = False
for k in sorted(ref):
    present = [n for n in cats if k in cats[n]]
    if present and len(present) < len(cats):
        miss = [n for n in cats if k not in cats[n]]
        print(f"FAIL [shared-key]: dotted key {k!r} is referenced from shared code "
              f"(linked by all apps) and exists in {present} but is MISSING from "
              f"{miss} — it will render the raw key there. Add it to those catalogs.",
              file=sys.stderr)
        bad = True
if bad:
    sys.exit(1)
PY

# 3) The SudokuAppCompositionTests SwiftPM fixture must be a byte-copy of the shipping
#    Sudoku catalog (no hand-edited drift). Regenerate via `mise run
#    gen:l10n_fixture` if this fails.
FIXTURE="$REPO_ROOT/Packages/SudokuKit/Tests/SudokuAppCompositionTests/Resources/Localizable.xcstrings.json"
SUDOKU="$REPO_ROOT/App/Sudoku/Resources/Localizable.xcstrings"
if [ -f "$FIXTURE" ] && [ -f "$SUDOKU" ]; then
  if ! cmp -s "$FIXTURE" "$SUDOKU"; then
    echo "FAIL [fixture]: $FIXTURE drifted from shipping catalog. Run: mise run gen:l10n_fixture" >&2
    fail=1
  fi
else
  echo "ERROR [fixture]: fixture or shipping catalog missing" >&2
  fail=1
fi

# 4) Same byte-copy guard for the PrivacyInfo manifest fixture (PrivacyManifestTests
#    reads the bundled copy via Bundle.module). Regenerate via `mise run
#    gen:privacy_fixture` if this fails.
PRIVACY_FIXTURE="$REPO_ROOT/Packages/SudokuKit/Tests/SudokuAppCompositionTests/Resources/PrivacyInfo.xcprivacy"
PRIVACY_SRC="$REPO_ROOT/App/Sudoku/Resources/PrivacyInfo.xcprivacy"
if [ -f "$PRIVACY_FIXTURE" ] && [ -f "$PRIVACY_SRC" ]; then
  if ! cmp -s "$PRIVACY_FIXTURE" "$PRIVACY_SRC"; then
    echo "FAIL [fixture]: $PRIVACY_FIXTURE drifted from shipping manifest. Run: mise run gen:privacy_fixture" >&2
    fail=1
  fi
else
  echo "ERROR [fixture]: PrivacyInfo fixture or shipping manifest missing" >&2
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "L10n gate FAILED." >&2
  exit 1
fi
echo "L10n gate passed: all 3 catalogs 0 placeholders, all 7 locales complete."
