#!/usr/bin/env bash
#MISE description="Screen-tour (#510): deep-link + screenshot every app screen in light & dark for fast UI/UX-designer review. Builds a DEBUG sim app (the -uitest-route / near-win hooks are DEBUG-only) and walks home → daily → practice → board → settings on the iOS Simulator. Output: build/tour/<app>/<appearance>/NN-screen.png."
#USAGE flag "--app <app>" help="Which app(s) to tour" default="all" {
#USAGE   choices "sudoku" "minesweeper" "all"
#USAGE }
#USAGE flag "--udid <udid>" help="Simulator UDID (default: first booted, else boot an iPhone 17 Pro)" default=""
#USAGE flag "--no-build" help="Skip build+install; tour the already-installed app" default="false"
#
# Each screen is reached in ONE launch via the #510 launch hooks — no manual
# tapping — so the whole tour is deterministic and re-runnable. Board uses the
# near-win-modal hook (a board one move from a win); the rest use -uitest-route.
#
# Hand the output folder to a designer: every screen, both appearances, side by
# side. Re-run after a UI change to refresh.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$REPO_ROOT"

APP="${usage_app:-all}"
UDID="${usage_udid:-}"
NO_BUILD="${usage_no_build:-false}"

DERIVED="build/tour-sim"
OUT_ROOT="build/tour"

scheme_for() { case "$1" in sudoku) echo "Sudoku";; minesweeper) echo "Minesweeper";; *) echo "";; esac; }
bundle_for() { case "$1" in sudoku) echo "com.wei18.sudoku";; minesweeper) echo "com.wei18.minesweeper";; *) echo "";; esac; }

# ── Post-build unresolved-xcconfig gate (#863) ────────────────────────────
# A hand-created worktree missing gitignored Tuist/*.xcconfig (see
# .worktreeinclude — the automatic copy only runs for HARNESS-created
# worktrees) still builds fine: `#include?` treats a missing xcconfig as
# empty, not an error. What that does to the Info.plist substitution
# $(ADMOB_BANNER_UNIT_ID) depends on WHICH xcconfig is missing (empirically
# verified #863):
#   - Tuist/Signing.xcconfig present but Tuist/AdMob.xcconfig absent:
#     Signing.xcconfig `#include`s AdMob.xcconfig NON-optionally, so this
#     combination hard-FAILS the xcodebuild step itself — safe already.
#   - Both files absent (the actual hand-worktree scenario — neither ever
#     got copied): the build SUCCEEDS and xcodebuild resolves the undefined
#     macro to an EMPTY STRING, not the literal "$(...)" text.
# So the runtime guard this mirrors (MakeGameApp.swift ~138-149, which covers
# GADBannerUnitID only — GADApplicationIdentifier is validated by the AdMob
# SDK itself at launch, no app-code precondition) checks BOTH `.isEmpty` and
# `.hasPrefix("$(")` — this gate checks both KEYS defensively since either
# empty value crashes at launch. The literal-"$("
# scan stays generic (any string value, not just the two known keys, per
# #863's ask — catches a FUTURE substituted key left unresolved by some
# other xcconfig combination); the emptiness check is scoped to the two
# keys we know are build-injected, since "empty" alone is not inherently
# wrong for arbitrary Info.plist strings.
check_plist_resolved() {
  local app_path="$1" plist="$1/Info.plist"
  if [[ ! -f "$plist" ]]; then
    echo "error: no Info.plist found at $plist — cannot verify xcconfig substitution." >&2
    return 1
  fi
  local unresolved problems=()
  unresolved="$(plutil -p "$plist" | grep -oE '\$\([A-Za-z0-9_]+\)' | sort -u || true)"
  if [[ -n "$unresolved" ]]; then
    while IFS= read -r var; do problems+=("unresolved literal: $var"); done <<<"$unresolved"
  fi
  for key in GADApplicationIdentifier GADBannerUnitID; do
    local val
    val="$(/usr/libexec/PlistBuddy -c "Print :$key" "$plist" 2>/dev/null || true)"
    [[ -z "$val" ]] && problems+=("empty (missing xcconfig substitution): $key")
  done
  if [[ ${#problems[@]} -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────" >&2
    echo " UNRESOLVED/MISSING BUILD-TIME VALUE(S) in $plist:" >&2
    printf '   %s\n' "${problems[@]}" >&2
    echo "" >&2
    echo " A gitignored Tuist/*.xcconfig is missing from this checkout ($app_path) —" >&2
    echo " likely a hand-created worktree (git worktree add) that never got" >&2
    echo " .worktreeinclude's automatic copy. Remedy: from the MAIN checkout run" >&2
    echo "   mise run worktree:seed $REPO_ROOT" >&2
    echo " (that's THIS worktree's path — worktree:seed copies Tuist/*.xcconfig" >&2
    echo " + secrets/ into it) — or build from the main checkout instead." >&2
    echo " Refusing to install a launch-crashing app onto the shared simulator." >&2
    echo "────────────────────────────────────────────────────────────────" >&2
    return 1
  fi
}

# (screen-key, launch-arg) pairs — empty arg = default launch (home).
SCREENS=(
  "01-home:"
  "02-daily:-uitest-route daily"
  "03-practice:-uitest-route practice"
  "04-board:-uitest-near-win-modal"
  "05-settings:-uitest-route settings"
)

# ── Resolve the simulator ──────────────────────────────────────────────
if [[ -z "$UDID" ]]; then
  UDID="$(xcrun simctl list devices booted 2>/dev/null | grep -Eo '[0-9A-F-]{36}' | head -1 || true)"
fi
if [[ -z "$UDID" ]]; then
  UDID="$(xcrun simctl list devices available | grep -E 'iPhone 17 Pro \(' | grep -Eo '[0-9A-F-]{36}' | head -1)"
  [[ -n "$UDID" ]] || { echo "error: no 'iPhone 17 Pro' simulator found in available devices" >&2; exit 1; }
  echo "==> booting iPhone 17 Pro ($UDID)"
  xcrun simctl boot "$UDID"
fi
until xcrun simctl list devices booted | grep -q "$UDID"; do sleep 2; done
echo "==> simulator: $UDID"

# ── Apps to tour ───────────────────────────────────────────────────────
APPS=()
case "$APP" in
  all) APPS=(sudoku minesweeper);;
  *) APPS=("$APP");;
esac

if [[ "$NO_BUILD" != "true" ]]; then
  echo "==> tuist generate (workspace is gitignored)"
  mise exec -- tuist install >/dev/null 2>&1
  mise exec -- tuist generate --no-open >/dev/null 2>&1
fi

PRODUCTS="$DERIVED/Build/Products/Debug-iphonesimulator"

for app in "${APPS[@]}"; do
  scheme="$(scheme_for "$app")"; bundle="$(bundle_for "$app")"
  [[ -z "$scheme" ]] && { echo "unknown app: $app" >&2; exit 2; }

  if [[ "$NO_BUILD" != "true" ]]; then
    echo "==> build $scheme (Debug, iphonesimulator)"
    xcodebuild -workspace Game.xcworkspace -scheme "$scheme" \
      -sdk iphonesimulator -configuration Debug \
      -destination "platform=iOS Simulator,id=$UDID" \
      -derivedDataPath "$DERIVED" build >/dev/null
    check_plist_resolved "$PRODUCTS/$scheme.app"
    xcrun simctl install "$UDID" "$PRODUCTS/$scheme.app"
  fi

  for mode in light dark; do
    xcrun simctl ui "$UDID" appearance "$mode" >/dev/null 2>&1 || true
    dir="$OUT_ROOT/$app/$mode"; mkdir -p "$dir"
    echo "==> $app · $mode"
    for entry in "${SCREENS[@]}"; do
      key="${entry%%:*}"; arg="${entry#*:}"
      xcrun simctl terminate "$UDID" "$bundle" >/dev/null 2>&1 || true
      # shellcheck disable=SC2086
      xcrun simctl launch "$UDID" "$bundle" $arg >/dev/null 2>&1 || true
      sleep 3
      # Capture stderr (simctl io chatters there even on success) and surface
      # it only on failure — clean success output, diagnostic failure output.
      if err="$(xcrun simctl io "$UDID" screenshot "$dir/$key.png" 2>&1 >/dev/null)"; then
        echo "    $key.png"
      else
        echo "    $key.png (FAILED): $err"
      fi
    done
  done
  xcrun simctl terminate "$UDID" "$bundle" >/dev/null 2>&1 || true
done

xcrun simctl ui "$UDID" appearance light >/dev/null 2>&1 || true
echo "==> done. Tour screenshots: $OUT_ROOT/<app>/<light|dark>/NN-screen.png"
