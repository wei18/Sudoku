    "\"Not now\" keeps this for later — it does not ask iOS yet." : {
      "comment" : "#287 Settings Reminders entry — local-notification daily reminder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Not now\" keeps this for later — it does not ask iOS yet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ahora no\" lo guarda para más tarde: aún no se le pide permiso a iOS."
