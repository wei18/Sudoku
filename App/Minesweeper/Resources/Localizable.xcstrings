          }
        }
      }
    },
    "Notifications are turned off for Minesweeper in Settings, so we can't tell you when the Daily is ready." : {
      "comment" : "#287 Settings Reminders entry — local-notification daily reminder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications are turned off for Minesweeper in Settings, so we can't tell you when the Daily is ready."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones de Buscaminas están desactivadas en Ajustes, así que no podemos avisarte cuando el reto diario esté listo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マインスイーパーの通知が設定でオフになっているため、デイリーの準備ができてもお知らせできません。"
