          }
        }
      }
    },
    "We'll let you know the moment tomorrow's Daily Minesweeper is ready." : {
      "comment" : "#287 Settings Reminders entry — local-notification daily reminder.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We'll let you know the moment tomorrow's Daily Minesweeper is ready."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te avisaremos en cuanto esté listo el Buscaminas diario de mañana."
