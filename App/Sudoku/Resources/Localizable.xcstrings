    "Couldn't clear cache" : {
      "comment" : "#687 Settings — failure toast shown when the Clear cache action's delete throws (the error also funnels through ErrorReporter). Mirrors MinesweeperKit's entry (#284).",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
