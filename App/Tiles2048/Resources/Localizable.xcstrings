{
  "sourceLanguage": "en",
  "strings": {
    "\"Not now\" keeps this for later — it does not ask iOS yet.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Not now\" keeps this for later — it does not ask iOS yet."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「暫時不要」會保留稍後詢問的機會——現在不會要求 iOS 授權。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「暂不」会保留稍后询问的机会——现在不会要求 iOS 授权。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「後で」を選ぶと後から確認できます――今は iOS に許可を求めません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"나중에\"는 나중을 위해 남겨두는 거예요 — 지금은 iOS에 묻지 않아요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ahora no\" lo guarda para más tarde — aún no le pregunta a iOS."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "\"ไว้ภายหลัง\" จะเก็บไว้ถามทีหลัง — ยังไม่ขอ iOS ตอนนี้"
          }
        }
      },
      "comment": "#479 SDD-005 — reminder primer fineprint for 2048 Tiles."
    },
    "2048 reached!": {
      "comment": "SDD-004 M3 — achievement banner shown in the stuck overlay when the player reached the 2048 tile.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2048 reached!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Llegaste a 2048!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2048に到達しました！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "2048 달성!"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ถึง 2048 แล้ว!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "达到2048！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "達到2048！"
          }
        }
      }
    },
