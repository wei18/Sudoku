<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>{{TITLE}}</title>
<style>
:root {
  --bg: #fafaf7;
  --fg: #1a1a1a;
  --muted: #666;
  --accent: #007aff;
  --warn: #d93025;
  --ok: #1a7f37;
  --code-bg: #f0f0eb;
  --border: #d8d6cf;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #1e1e1e;
    --fg: #e8e6df;
    --muted: #999;
    --accent: #60a5fa;
    --warn: #ef6962;
    --ok: #6cc66c;
    --code-bg: #2a2a2a;
    --border: #3a3a3a;
  }
}
body {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", sans-serif;
  background: var(--bg);
  color: var(--fg);
  max-width: 780px;
  margin: 0 auto;
  padding: 32px 24px 80px;
  line-height: 1.6;
  font-size: 16px;
}
h1 { font-size: 28px; margin-bottom: 8px; }
.subtitle { color: var(--muted); margin-bottom: 32px; }
.step {
  background: var(--code-bg);
  border-radius: 12px;
  padding: 20px 24px;
  margin: 24px 0;
  border-left: 4px solid var(--accent);
}
.step h2 {
  margin-top: 0;
  font-size: 18px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.step-num {
  background: var(--accent);
  color: white;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 14px;
}
.url-badge {
  display: inline-block;
  background: var(--bg);
  padding: 4px 10px;
  border-radius: 6px;
  font-family: "SF Mono", Menlo, monospace;
  font-size: 13px;
  border: 1px solid var(--border);
  margin: 8px 0;
}
.url-badge a { color: var(--accent); text-decoration: none; }
.url-badge a:hover { text-decoration: underline; }
ul { padding-left: 24px; }
li { margin: 8px 0; }
code, .copy {
  font-family: "SF Mono", Menlo, monospace;
  background: var(--bg);
  padding: 2px 8px;
  border-radius: 4px;
  border: 1px solid var(--border);
  font-size: 14px;
  cursor: pointer;
  user-select: all;
}
code:hover, .copy:hover { background: var(--accent); color: white; border-color: var(--accent); }
.checkbox {
  display: inline-block;
  width: 18px;
  height: 18px;
  border: 2px solid var(--border);
  border-radius: 4px;
  vertical-align: middle;
  margin-right: 8px;
  cursor: pointer;
  background: var(--bg);
}
.checkbox:checked {
  background: var(--ok);
  border-color: var(--ok);
}
.field-row {
  margin: 12px 0;
  padding: 8px 12px;
  background: var(--bg);
  border-radius: 6px;
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 12px;
  align-items: center;
}
.field-label { color: var(--muted); font-size: 14px; }
.field-value { font-family: "SF Mono", Menlo, monospace; font-size: 14px; user-select: all; }
.warn {
  background: rgba(217, 48, 37, 0.1);
  border-left: 3px solid var(--warn);
  padding: 12px 16px;
  border-radius: 6px;
  margin: 16px 0;
}
.warn::before { content: "⚠️ "; }
.danger {
  background: rgba(217, 48, 37, 0.15);
  border-left: 4px solid var(--warn);
  padding: 14px 18px;
  border-radius: 6px;
  margin: 20px 0;
  font-weight: 500;
}
.danger::before { content: "🚨 "; }
.ok-note {
  background: rgba(26, 127, 55, 0.08);
  border-left: 3px solid var(--ok);
  padding: 12px 16px;
  border-radius: 6px;
  margin: 16px 0;
}
.ok-note::before { content: "✓ "; }
.tag {
  display: inline-block;
  background: var(--border);
  color: var(--fg);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  margin-left: 8px;
  font-weight: normal;
}
.section-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 40px 0;
}
.done-banner {
  background: var(--ok);
  color: white;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  margin: 32px 0;
}
.done-banner h3 { margin: 0 0 8px; }
.id-box {
  background: var(--bg);
  border: 2px dashed var(--accent);
  border-radius: 8px;
  padding: 16px;
  margin: 16px 0;
  font-family: "SF Mono", Menlo, monospace;
  font-size: 14px;
}
.id-box-label {
  color: var(--muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
  font-family: -apple-system, sans-serif;
}
.id-box-input {
  display: block;
  width: 100%;
  background: transparent;
  border: none;
  color: var(--fg);
  font-family: inherit;
  font-size: 15px;
  padding: 4px 0;
  outline: none;
}
.diagram {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  font-family: "SF Mono", Menlo, monospace;
  font-size: 13px;
  white-space: pre;
  margin: 16px 0;
}
</style>
</head>
<body>

<h1>{{HEADING}}</h1>
<p class="subtitle">{{SUBTITLE}}</p>

{{BODY}}

<p style="margin-top: 48px; color: var(--muted); font-size: 13px; text-align: center;">
  File: <code>{{OUT_PATH}}</code>
</p>

</body>
</html>
