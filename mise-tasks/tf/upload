#!/usr/bin/env bash
#MISE description="LOCAL archive → export → TestFlight upload (temporary Xcode-Cloud substitute while XCC quota is exhausted). archive/export are safe; the upload step is USER-OWNED and gated behind --i-am-sure. Reads ASC API creds from secrets/.env — never hardcoded."
#USAGE arg "<app>" help="App to archive and upload (\"all\" = sudoku + minesweeper)" {
#USAGE   choices "sudoku" "minesweeper" "all"
#USAGE }
#USAGE arg "<platform>" help="Target platform" {
#USAGE   choices "ios" "macos" "all"
#USAGE }
#USAGE flag "--archive-only" help="Archive + export only; never upload (safe default)"
#USAGE flag "--build <number>" help="Explicit CFBundleVersion; default = UTC timestamp (YYYYMMDDhhmm)"
#USAGE flag "--config <name>" help="xcodebuild configuration" default="Release"
#USAGE flag "--i-am-sure" help="REQUIRED to actually upload to TestFlight (user-owned, irreversible)"
#USAGE flag "--changelog-only" help="Print+write the What-to-Test changelog only; no archive/export/upload/tag"
#USAGE flag "--full" help="Changelog: include ALL commits (no docs/chore/ci/skill/spec/meetings filtering), keep (#NNN) refs"
#USAGE flag "--since <ref>" help="Changelog base ref when no prior tf/<app>-<plat>/* tag exists (ignored if a prior tag exists)"
#USAGE flag "--force-archive" help="Skip fingerprint reuse; always re-run xcodebuild archive even if source+config are unchanged (#670 PR1)"
#
# Temporary stand-in for the Xcode Cloud "Main CI" workflow (docs/foundations.md
# §4 table: Build + Archive + upload internal TestFlight) for the window where the
# XCC monthly compute quota is exhausted. Mirrors the scriptable-ops precedent of
# `mise-tasks/ck/schema` (#337) + `mise-tasks/store/screenshots` (#311): a
# commit-tracked, idempotent, Production-gated wrapper around Apple CLIs.
#
# PIPELINE (per app + platform):
#   1. generate : `tuist generate` (the *.xcworkspace is gitignored — must exist)
#   2. archive  : `xcodebuild archive` → build/<app>-<plat>.xcarchive. SKIPPED
#                 when a fingerprint file matches the current HEAD + dirty-tree
#                 + app/platform/config + rendered Tuist/AdMob.xcconfig AND the
#                 prior .xcarchive still exists (#670 PR1) — retrying a failed
#                 upload then costs export+upload only, not the 5-8 min archive.
#                 `--force-archive` always re-archives.
#   3. bump     : patch the archived app's CFBundleVersion to a UNIQUE build number
#                 (TestFlight rejects duplicate build numbers for a CFBundleShort-
#                 VersionString). Default = UTC timestamp; override with --build.
#   4. export   : `xcodebuild -exportArchive` with a runtime-generated
#                 ExportOptions.plist (App-Store-Connect method) → .ipa / .pkg
#   5. upload   : `xcrun altool --upload-app` to TestFlight, authenticated with the
#                 ASC API key (.p8 + key-id + issuer) from secrets/.env. GATED.
#   6. tag+log  : on a REAL upload success, tag `tf/<app>-<plat>/<build>` (pushed,
#                 best-effort) and write a What-to-Test changelog since the prior
#                 such tag (#694 P1). `--changelog-only` runs just this step, for
#                 any app/platform/build, without touching archive/export/upload.
#
# <app> = "all" (#670 PR2): steps 1-4 (admob render → generate → archive → bump
#   → export) run SEQUENTIALLY, one app at a time. This is NOT an accident of
#   laziness — `Tuist/AdMob.xcconfig` and `Game.xcworkspace` are single,
#   app-agnostic paths shared by the whole repo (Tuist project structure, not
#   this script's choice). Two apps archiving concurrently would each render
#   their OWN AdMob values into that ONE xcconfig and `tuist generate` that ONE
#   workspace, racing each other — worst case, app A's binary gets app B's
#   AdMob ID compiled in, silently (no error, wrong ad attribution/revenue).
#   Only step 5 (upload, network-bound and genuinely independent per app) fans
#   out in parallel — one background `xcrun altool` job per exported package,
#   `wait`ed together, exit codes collected per app so one app's failure never
#   blocks or hides another app's success. Step 6 (tag+log) then runs per app
#   that uploaded successfully, sequentially (cheap, per-app-named files/tags,
#   no lock needed — see #670 PR2 scope note).
#
# AUTH: ASC API key. Reuses the SAME secrets/.env keys as ASCRegister
#   (ASC_API_KEY_PATH / ASC_API_KEY_ID / ASC_API_ISSUER_ID) plus the team id
#   (reuses CK_TEAM_ID — the single 10-char Apple Developer Team ID already in
#   .env for cktool). Nothing new is invented; nothing is printed.
#
# SAFETY:
#   - archive + export touch only build/ (gitignored). Safe to run repeatedly.
#   - upload is the only irreversible, user-owned step → REFUSES without
#     --i-am-sure, and prints a "user-owned signing, confirm" banner first.
#   - --archive-only stops after export (produces the .ipa/.pkg, no upload).
#   - --changelog-only never archives/exports/uploads/tags; it only reads git
#     history. A failed tag push after a real upload is a WARNING, not a failure
#     — the upload already happened and must not be reported as failed because a
#     git push hiccuped.
#   - <app> all (#670 PR2): archive/export stays SEQUENTIAL per app (shared
#     Tuist/AdMob.xcconfig + Game.xcworkspace paths — see PIPELINE note above);
#     only the upload step parallelizes. --i-am-sure is one confirmation for the
#     WHOLE batch (both apps' uploads), not one per app. One app's upload
#     failure does not stop or roll back the other app's upload, changelog, or
#     tag — the task exits non-zero overall but prints which app(s) failed.
#
# Usage:
#   mise run tf:upload <sudoku|minesweeper|all> <ios|macos|all> [flags]
#
#   flags:
#     --archive-only     archive + export only; never upload (default-safe)
#     --build <N>        explicit CFBundleVersion (build number); default = $(date -u +%Y%m%d%H%M)
#     --config <name>    xcodebuild configuration (default: Release)
#     --i-am-sure        REQUIRED to actually upload to TestFlight (user-owned;
#                         with <app> all, gates BOTH apps' uploads at once)
#     --changelog-only   print+write the What-to-Test changelog only (no build)
#     --full             changelog: no noise filtering, keep (#NNN) refs
#     --since <ref>      changelog base when no prior tf/<app>-<plat>/* tag exists
#     --force-archive    always re-run xcodebuild archive (skip fingerprint reuse)
#     -h | --help        this help
#
# Examples:
#   mise run tf:upload sudoku ios --archive-only           # safe: produce .ipa
#   mise run tf:upload sudoku all --archive-only           # iOS .ipa + macOS .pkg
#   mise run tf:upload sudoku ios --i-am-sure              # archive+export+UPLOAD
#   mise run tf:upload minesweeper macos --build 20260605 --i-am-sure
#   mise run tf:upload sudoku ios --i-am-sure --force-archive        # retry: skip fingerprint reuse
#   mise run tf:upload sudoku ios --changelog-only                  # dry-run changelog only
#   mise run tf:upload sudoku ios --changelog-only --since abc1234  # first-run baseline
#   mise run tf:upload sudoku ios --changelog-only --full           # unfiltered, with (#NNN)
#   mise run tf:upload all ios --archive-only                       # both apps, sequential archive
#   mise run tf:upload all ios --i-am-sure                          # both apps, PARALLEL upload (#670 PR2)
#   mise run tf:upload all all --changelog-only                     # 4 changelogs (2 apps x 2 platforms)
#
set -euo pipefail

# ── Public, non-secret config (already in Project.swift / entitlements) ───────
scheme_for() { case "$1" in sudoku) echo "Sudoku";; minesweeper) echo "Minesweeper";; *) echo "";; esac; }
bundle_for() { case "$1" in sudoku) echo "com.wei18.sudoku";; minesweeper) echo "com.wei18.minesweeper";; *) echo "";; esac; }

usage() {
    sed -n '2,107p' "$0" | sed 's/^#MISE[^=]*=//; s/^# \{0,1\}//'
    exit "${1:-1}"
}

# ── Arg parsing ───────────────────────────────────────────────────────────────
# Positionals: <app> <platform>, then optional flags.
APP="${1:-}";  shift || true
PLAT="${1:-}"; shift || true

CONFIG="Release"
BUILD_NUMBER="$(date -u +%Y%m%d%H%M)"   # unique-by-minute default; --build overrides
ARCHIVE_ONLY=0
SURE=0
CHANGELOG_ONLY=0
CHANGELOG_FULL=0
SINCE_REF=""
FORCE_ARCHIVE=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --archive-only)    ARCHIVE_ONLY=1; shift ;;
        --i-am-sure)       SURE=1; shift ;;
        --build)           BUILD_NUMBER="${2:-}"; shift 2 ;;
        --config)          CONFIG="${2:-}"; shift 2 ;;
        --changelog-only)  CHANGELOG_ONLY=1; shift ;;
        --full)            CHANGELOG_FULL=1; shift ;;
        --since)           SINCE_REF="${2:-}"; shift 2 ;;
        --force-archive)   FORCE_ARCHIVE=1; shift ;;
        -h|--help)         usage 0 ;;
        *) echo "error: unknown argument '$1'" >&2; usage ;;
    esac
done

case "$APP" in sudoku|minesweeper|all) ;; -h|--help|"") usage 0 ;; *) echo "error: app must be sudoku|minesweeper|all (got '$APP')" >&2; usage ;; esac
case "$PLAT" in ios|macos|all) ;; *) echo "error: platform must be ios|macos|all (got '$PLAT')" >&2; usage ;; esac
[[ -n "$BUILD_NUMBER" ]] || { echo "error: --build value is empty" >&2; exit 1; }

# <app> "all" (#670 PR2) expands to both apps. SCHEME/BUNDLE are NOT computed
# here (unlike <plat>) because they are per-app — they get (re)assigned inside
# the sequential archive/export loop below, once per iteration.
if [[ "$APP" == "all" ]]; then
    TARGET_APPS=(sudoku minesweeper)
else
    TARGET_APPS=("$APP")
fi
REPO_ROOT="$(git rev-parse --show-toplevel)"
WORKSPACE="$REPO_ROOT/Game.xcworkspace"
BUILD_DIR="$REPO_ROOT/build/testflight"
mkdir -p "$BUILD_DIR"

# ── Changelog (#694 P1): tag-per-upload diffing + PR-title "What to Test" ──────
# Independent of archive/export/upload/creds — only reads git history, so
# --changelog-only can verify it without building anything.
tf_tag_for() { echo "tf/${1}-${2}/${3}"; }   # $1=app $2=plat $3=build

# Latest tf/<app>-<plat>/* tag = the previous uploaded build for this app+
# platform. Build numbers are UTC-minute timestamps, so lexical sort ==
# chronological sort.
latest_tf_tag() {
    git -C "$REPO_ROOT" tag -l "tf/${1}-${2}/*" | sort | tail -1
}

# Split one PR-title subject (`type(scope): desc` or `type: desc`) into
# type / scope / desc, joined by \x1F (a non-whitespace delimiter — `read`
# collapses consecutive TAB/space/newline delimiters, which would silently
# swallow an empty `scope` field and shift `desc` into it for no-scope
# subjects like `fix: ...`). Falls back to type=other for pre-Conventional-
# Commits history. Prints "type<US>scope<US>desc".
classify_subject() {
    local subject="$1" us=$'\x1f'
    if [[ "$subject" =~ ^([a-zA-Z0-9]+)\(([^\)]*)\)!?:[[:space:]]*(.*)$ ]]; then
        printf '%s%s%s%s%s\n' "${BASH_REMATCH[1]}" "$us" "${BASH_REMATCH[2]}" "$us" "${BASH_REMATCH[3]}"
    elif [[ "$subject" =~ ^([a-zA-Z0-9]+)!?:[[:space:]]*(.*)$ ]]; then
        printf '%s%s%s%s%s\n' "${BASH_REMATCH[1]}" "$us" "" "$us" "${BASH_REMATCH[2]}"
    else
        printf '%s%s%s%s%s\n' "other" "$us" "" "$us" "$subject"
    fi
}

# Noise filter for the default (non --full) tester-facing changelog (#694 §2):
# drop docs/chore/ci commits and skill/spec/meetings-only meta commits even
# when their type is feat/fix (e.g. `feat(skills): add ... skill`).
is_changelog_noise() {
    local type="$1" scope="$2" desc="$3"
    case "$type" in docs|chore|ci) return 0 ;; esac
    case "$scope" in *skill*|*spec*|*meetings*) return 0 ;; esac
    case "$desc" in *"meetings"*) return 0 ;; esac
    return 1
}

# Build the Fixes/Features/Other changelog body for (base_ref, HEAD].
# base_ref="" means "from the start of history" (used when no prior tag AND no
# --since exist). $2 = 1 for --full (no noise filter, keeps trailing (#NNN)).
generate_changelog_body() {
    local base_ref="$1" full="$2"
    local range="HEAD"
    [[ -n "$base_ref" ]] && range="${base_ref}..HEAD"

    local features=() fixes=() other=()
    local subject type scope desc line
    while IFS= read -r subject; do
        [[ -n "$subject" ]] || continue
        IFS=$'\x1f' read -r type scope desc <<<"$(classify_subject "$subject")"
        if [[ "$full" -ne 1 ]] && is_changelog_noise "$type" "$scope" "$desc"; then
            continue
        fi
        line="$desc"
        if [[ "$full" -ne 1 ]]; then
            # tester-facing short form: strip trailing " (#NNN)" ref(s).
            while [[ "$line" =~ ^(.*)[[:space:]]\(#[0-9]+\)$ ]]; do
                line="${BASH_REMATCH[1]}"
            done
        fi
        case "$type" in
            feat) features+=("$line") ;;
            fix)  fixes+=("$line") ;;
            *)    other+=("$line") ;;
        esac
    done < <(git -C "$REPO_ROOT" log "$range" --format='%s')

    echo "Fixes"
    if [[ ${#fixes[@]} -gt 0 ]]; then printf -- '- %s\n' "${fixes[@]}"; else echo "- (none)"; fi
    echo "Features"
    if [[ ${#features[@]} -gt 0 ]]; then printf -- '- %s\n' "${features[@]}"; else echo "- (none)"; fi
    if [[ ${#other[@]} -gt 0 ]]; then
        echo "Other"
        printf -- '- %s\n' "${other[@]}"
    fi
}

# Resolve the base ref (prior tf tag → --since → full history, with a clear
# warning on the full-history fallback), generate the body, print it framed,
# and write build/testflight/<app>-<plat>-<build>-changelog.md.
run_changelog() {
    local app="$1" plat="$2" build="$3"
    local prev_tag base_ref base_desc
    prev_tag="$(latest_tf_tag "$app" "$plat")"
    if [[ -n "$prev_tag" ]]; then
        base_ref="$prev_tag"; base_desc="prior tag $prev_tag"
    elif [[ -n "$SINCE_REF" ]]; then
        base_ref="$SINCE_REF"; base_desc="--since $SINCE_REF"
    else
        base_ref=""
        base_desc="FULL history (no prior tf/${app}-${plat}/* tag and no --since given)"
        echo "warning: no prior tf/${app}-${plat}/* tag and no --since given — changelog covers the entire history." >&2
    fi

    # Guard: an unresolvable base ref (bad --since, corrupt prior tag) would
    # make `git log` fail inside the process substitution — invisible to
    # `set -e` — and emit an EMPTY "(none)/(none)" changelog that looks real.
    # Fail loudly instead of writing a lying .md. `return 1` (not `exit`):
    # under --changelog-only the bare call still aborts via `set -e`, while
    # the post-upload caller downgrades it to a warning — a completed upload
    # must never be reported as failed over a changelog hiccup.
    if [[ -n "$base_ref" ]] && ! git -C "$REPO_ROOT" rev-parse -q --verify "$base_ref^{commit}" >/dev/null 2>&1; then
        echo "error: changelog base ref '$base_ref' does not resolve to a commit ($base_desc)." >&2
        return 1
    fi

    local body out
    body="$(generate_changelog_body "$base_ref" "$CHANGELOG_FULL")"
    out="$BUILD_DIR/${app}-${plat}-${build}-changelog.md"

    echo "────────────────────────────────────────────────────────────────"
    echo " CHANGELOG (What to Test) — $app · $plat · build $build"
    echo " since: $base_desc$( [[ $CHANGELOG_FULL -eq 1 ]] && echo ' [--full]' )"
    echo "────────────────────────────────────────────────────────────────"
    printf '%s\n' "$body"
    echo "────────────────────────────────────────────────────────────────"
    printf '%s\n' "$body" > "$out"
    echo "==> wrote $out"
}

# On a REAL upload success only: tag `tf/<app>-<plat>/<build>` (pushed,
# best-effort). Never fails the task — the upload already happened, so a tag
# or push hiccup is a warning, not an error.
create_and_push_tf_tag() {
    local app="$1" plat="$2" build="$3" tag
    tag="$(tf_tag_for "$app" "$plat" "$build")"
    if git -C "$REPO_ROOT" rev-parse -q --verify "refs/tags/$tag" >/dev/null 2>&1; then
        # Local tag exists (e.g. a re-run of the same build after a failed
        # push) — don't re-create it, but still retry the push if origin
        # doesn't have it yet.
        echo "warning: git tag $tag already exists locally — skipping tag creation." >&2
        if [[ -n "$(git -C "$REPO_ROOT" ls-remote --tags origin "refs/tags/$tag" 2>/dev/null)" ]]; then
            echo "==> tag $tag already on origin — nothing to push."
            return 0
        fi
    else
        if git -C "$REPO_ROOT" tag "$tag" HEAD >/dev/null 2>&1; then
            echo "==> tagged $tag"
        else
            echo "warning: failed to create git tag $tag (upload already succeeded — tag it manually if needed)." >&2
            return 0
        fi
    fi
    if git -C "$REPO_ROOT" push origin "refs/tags/$tag" >/dev/null 2>&1; then
        echo "==> pushed tag $tag"
    else
        echo "warning: failed to push tag $tag to origin (upload already succeeded — push it manually: git push origin refs/tags/$tag)." >&2
    fi
}

if [[ "$CHANGELOG_ONLY" -eq 1 ]]; then
    # <app> all (#670 PR2): one changelog per app, same PLAT expansion as
    # single-app — aligns with the PR1-era "all" precedent for <platform>.
    for target_app in "${TARGET_APPS[@]}"; do
        case "$PLAT" in
            ios)   run_changelog "$target_app" ios "$BUILD_NUMBER" ;;
            macos) run_changelog "$target_app" macos "$BUILD_NUMBER" ;;
            all)   run_changelog "$target_app" ios "$BUILD_NUMBER"; run_changelog "$target_app" macos "$BUILD_NUMBER" ;;
        esac
    done
    exit 0
fi

# ── Auth loader: ASC API creds from secrets/.env (never echoed) ───────────────
# Sets globals: ASC_KEY_PATH ASC_KEY_ID ASC_ISSUER TEAM_ID. Validates presence,
# never prints the secret values.
load_asc_creds() {
    local env_file="$REPO_ROOT/secrets/.env"
    if [[ ! -f "$env_file" ]]; then
        echo "error: $env_file not found. Copy secrets/.env.example → secrets/.env and fill the ASC_* keys." >&2
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$env_file"
    ASC_KEY_PATH="${ASC_API_KEY_PATH:-}"
    ASC_KEY_ID="${ASC_API_KEY_ID:-}"
    ASC_ISSUER="${ASC_API_ISSUER_ID:-}"
    TEAM_ID="${CK_TEAM_ID:-}"   # reuse the single Team ID already in .env (cktool)
    local missing=()
    [[ -n "$ASC_KEY_ID" && "$ASC_KEY_ID" != REPLACE_KEY_ID ]]                   || missing+=("ASC_API_KEY_ID")
    [[ -n "$ASC_ISSUER" && "$ASC_ISSUER" != 00000000-0000-0000-0000-000000000000 ]] || missing+=("ASC_API_ISSUER_ID")
    [[ -n "$TEAM_ID" && "$TEAM_ID" != REPLACE_TEAM_ID ]]                        || missing+=("CK_TEAM_ID")
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "error: secrets/.env is missing real values for: ${missing[*]}" >&2
        echo "       fill them from project memory (asc-api-credentials + the Team ID)." >&2
        exit 1
    fi
    # altool locates the .p8 by KEY_ID inside one of its search dirs:
    #   ./private_keys, ~/private_keys, ~/.private_keys, ~/.appstoreconnect/private_keys
    # The repo convention puts the key at secrets/AuthKey_<KEY_ID>.p8 (gitignored).
    # We stage a per-run symlink into ./private_keys so altool finds it without
    # us ever copying or printing the key.
    local resolved="$ASC_KEY_PATH"
    [[ "$resolved" = /* ]] || resolved="$REPO_ROOT/$resolved"
    if [[ ! -f "$resolved" ]]; then
        echo "error: ASC API key not found at '$resolved' (ASC_API_KEY_PATH in secrets/.env)." >&2
        echo "       Move your AuthKey_<KEY_ID>.p8 into secrets/ and point ASC_API_KEY_PATH at it." >&2
        exit 1
    fi
    ASC_KEY_RESOLVED="$resolved"
}

# Stage the .p8 where altool searches, and clean it up on exit. The symlink is
# created under build/ (gitignored) and exposed to altool via the cwd's
# ./private_keys lookup by symlinking that too. No secret is copied or printed.
stage_key_for_altool() {
    PRIVATE_KEYS_DIR="$BUILD_DIR/private_keys"
    mkdir -p "$PRIVATE_KEYS_DIR"
    ln -sfn "$ASC_KEY_RESOLVED" "$PRIVATE_KEYS_DIR/AuthKey_${ASC_KEY_ID}.p8"
}

# ── ExportOptions.plist generator (runtime; TEAM_ID never committed) ──────────
# Writes an App-Store-Connect export options plist to $1 for the given platform.
# `destination=upload` would hand off to ASC directly, but we keep `export`
# (write .ipa/.pkg to disk) so --archive-only can stop here and the upload is a
# separate, explicitly-gated altool step.
write_export_options() {
    local out="$1" plat="$2"
    # macOS App Store export needs the same `app-store-connect` method (Xcode 15+
    # renamed `app-store` → `app-store-connect`; both still accepted by 16/26).
    /usr/libexec/PlistBuddy \
        -c "Add :method string app-store-connect" \
        -c "Add :teamID string $TEAM_ID" \
        -c "Add :signingStyle string automatic" \
        -c "Add :destination string export" \
        -c "Add :uploadSymbols bool true" \
        -c "Add :manageAppVersionAndBuildNumber bool false" \
        "$out" >/dev/null
}

# ── Fingerprint archive-reuse (#670 PR1) ──────────────────────────────────────
# Hashes every input that actually influences the ARCHIVE's bytes: the current
# commit, working-tree dirtiness (incl. untracked files), app/platform/config,
# and the RENDERED Tuist/AdMob.xcconfig content. The xcconfig (not secrets/.env
# directly) is hashed because at the call site (inside archive_export_platform,
# after render_admob_xcconfig + tuist generate have already run for this app)
# it is the file xcodebuild actually reads — hashing it also future-proofs any
# other secret injected via xcconfig, without enumerating env var names here.
#
# KNOWN BLIND SPOT: `git status --porcelain --untracked-files=all` reports each
# untracked file by NAME + status code ("?? path"), not by content. If an
# already-untracked file's CONTENT changes while its name/status stays "??",
# this fingerprint will NOT notice and a stale archive could be reused. This is
# a deliberate tradeoff — hashing the bytes of every untracked file on every
# invocation is too expensive for the common case of a clean-ish tree. Do not
# present this fingerprint as a perfect content hash of the working tree.
compute_fingerprint() {
    local plat="$1" admob_hash=""
    if [[ -f "$REPO_ROOT/Tuist/AdMob.xcconfig" ]]; then
        admob_hash="$(shasum -a 256 "$REPO_ROOT/Tuist/AdMob.xcconfig" | awk '{print $1}')"
    fi
    {
        git -C "$REPO_ROOT" rev-parse HEAD
        git -C "$REPO_ROOT" status --porcelain --untracked-files=all
        echo "$APP"
        echo "$plat"
        echo "$CONFIG"
        echo "$admob_hash"
    } | shasum -a 256 | awk '{print $1}'
}

# ── Per-platform archive+export (#670 PR2: upload split out, see below) ──────
# $1 = ios|macos. Uses the current $APP/$SCHEME/$BUNDLE globals — safe because
# this is only ever called from the SEQUENTIAL per-app loop, never from a
# background job. On success (and unless --archive-only), appends
# "$APP<US>$plat<US>$pkg<US>$upload_type" to the global EXPORT_RECORDS array
# for the later parallel upload stage to consume.
archive_export_platform() {
    local plat="$1"
    local destination archive_path export_dir
    case "$plat" in
        ios)   destination="generic/platform=iOS" ;;
        macos) destination="generic/platform=macOS" ;;
    esac
    archive_path="$BUILD_DIR/${APP}-${plat}.xcarchive"
    export_dir="$BUILD_DIR/${APP}-${plat}-export"
    local fp_file="$BUILD_DIR/${APP}-${plat}.fingerprint"
    local current_fp
    current_fp="$(compute_fingerprint "$plat")"

    echo "────────────────────────────────────────────────────────────────"
    echo " $APP ($BUNDLE) · $plat · scheme=$SCHEME · config=$CONFIG · build=$BUILD_NUMBER"
    echo "────────────────────────────────────────────────────────────────"

    # 1) archive ------------------------------------------------------------
    # Reuse the existing .xcarchive when the fingerprint (HEAD + dirty-tree +
    # app/plat/config + rendered AdMob.xcconfig) matches the one recorded for
    # it, unless --force-archive was passed. Skips only the xcodebuild archive
    # call (the 5-8 min step); bump/export/upload always run.
    if [[ "$FORCE_ARCHIVE" -ne 1 && -d "$archive_path" && -f "$fp_file" && "$(cat "$fp_file" 2>/dev/null)" == "$current_fp" ]]; then
        echo "==> fingerprint match ($current_fp) — reusing existing archive:"
        echo "    $archive_path"
        echo "    (source tree + Tuist/AdMob.xcconfig unchanged since this archive was built."
        echo "     Pass --force-archive to rebuild from scratch anyway.)"
    else
        echo "==> archive → $archive_path"
        xcodebuild archive \
            -workspace "$WORKSPACE" \
            -scheme "$SCHEME" \
            -configuration "$CONFIG" \
            -destination "$destination" \
            -archivePath "$archive_path" \
            CODE_SIGN_STYLE=Automatic \
            DEVELOPMENT_TEAM="$TEAM_ID" \
            | (command -v xcbeautify >/dev/null 2>&1 && xcbeautify || cat)
        # Only recorded once xcodebuild succeeds (set -o pipefail above makes a
        # failed archive abort the script before this line) — never fingerprint
        # a failed or partial archive as reusable.
        echo "$current_fp" > "$fp_file"
    fi

    # 2) bump build number on the ARCHIVED app's Info.plist ----------------------
    # CFBundleVersion is a hardcoded literal "1" in <App>/Info.plist (versions are
    # NOT driven by CURRENT_PROJECT_VERSION here), so an xcodebuild build-setting
    # override would not take effect. We patch the archive's embedded Info.plist
    # post-archive / pre-export — the canonical place agvtool-less projects bump.
    # Runs regardless of archive reuse (idempotent in-place overwrite).
    local app_plist
    app_plist="$(/usr/bin/find "$archive_path/Products/Applications" -maxdepth 2 -name Info.plist -path '*.app/Info.plist' | head -1)"
    if [[ -z "$app_plist" ]]; then
        echo "error: could not locate the archived app's Info.plist under $archive_path" >&2
        exit 1
    fi
    echo "==> bump CFBundleVersion → $BUILD_NUMBER  ($(basename "$(dirname "$app_plist")"))"
    /usr/libexec/PlistBuddy -c "Set :CFBundleVersion $BUILD_NUMBER" "$app_plist"

    # 3) export -----------------------------------------------------------------
    local opts="$BUILD_DIR/ExportOptions-${APP}-${plat}.plist"
    # NB: do NOT pre-`touch` this — PlistBuddy cannot parse a 0-length file
    # ("Cannot parse a NULL or zero-length data"). `rm` so write_export_options
    # starts clean; PlistBuddy auto-creates the file on first `Add`.
    rm -f "$opts"
    write_export_options "$opts" "$plat"
    rm -rf "$export_dir"
    echo "==> export (App Store Connect) → $export_dir"
    xcodebuild -exportArchive \
        -archivePath "$archive_path" \
        -exportPath "$export_dir" \
        -exportOptionsPlist "$opts" \
        -allowProvisioningUpdates \
        | (command -v xcbeautify >/dev/null 2>&1 && xcbeautify || cat)

    # Locate the produced package: .ipa (iOS) / .pkg (macOS).
    local pkg upload_type
    case "$plat" in
        ios)   pkg="$(/usr/bin/find "$export_dir" -maxdepth 1 -name '*.ipa' | head -1)"; upload_type="ios" ;;
        macos) pkg="$(/usr/bin/find "$export_dir" -maxdepth 1 -name '*.pkg' | head -1)"; upload_type="macos" ;;
    esac
    if [[ -z "$pkg" ]]; then
        echo "error: export produced no $( [[ $plat == ios ]] && echo .ipa || echo .pkg ) under $export_dir" >&2
        exit 1
    fi
    echo "==> exported: $pkg"

    if [[ "$ARCHIVE_ONLY" -eq 1 ]]; then
        echo "==> --archive-only: stopping before upload. Package is at:"
        echo "    $pkg"
        return 0
    fi

    EXPORT_RECORDS+=("${APP}${US}${plat}${US}${pkg}${US}${upload_type}")
}

# ── Parallel upload of one already-exported package (#670 PR2) ───────────────
# Runs as a BACKGROUND job — one per (app, plat) — so it must not rely on the
# $APP/$SCHEME/etc globals (those hold whichever app the sequential loop
# finished on last by the time jobs run); everything it needs comes in as an
# explicit argument. Writes its exit code to $5 (never lets a failed upload
# escape via `set -e` into the caller, which is backgrounded and can't be
# allowed to take the whole script down before siblings finish). Output is
# tagged "[app-plat]" so interleaved parallel altool logs stay attributable.
upload_one() {
    local app="$1" plat="$2" pkg="$3" upload_type="$4" result_file="$5"
    # altool finds the .p8 by --api-key id inside ./private_keys (staged once,
    # before any job starts, by the caller). The key path/contents are never
    # passed on argv. Flags verified against `xcrun altool --upload-app --help`
    # 2026-06-05: API-key auth uses hyphenated --api-key/--api-issuer.
    if ( cd "$BUILD_DIR" && xcrun altool --upload-app \
            --type "$upload_type" \
            --file "$pkg" \
            --api-key "$ASC_KEY_ID" \
            --api-issuer "$ASC_ISSUER" ) 2>&1 | sed "s/^/[${app}-${plat}] /"; then
        echo 0 > "$result_file"
    else
        echo "${PIPESTATUS[0]:-1}" > "$result_file"
    fi
}

# ── Prerequisites that gate every run ─────────────────────────────────────────
# AdMob.xcconfig from secrets/.env — local parity with ci_post_clone.sh §3.1b
# (XCC renders the same file from per-workflow Secret env vars). Per-app keys:
# SUDOKU_ADMOB_APP_ID / SUDOKU_ADMOB_BANNER_UNIT_ID and the MINESWEEPER_*
# twins. When the pair is present the file is (re)written for THIS app's
# archive — Debug builds still force Google's test ad unit in code, so prod
# values here never serve live ads from a dev run. When absent, whatever
# Tuist/AdMob.xcconfig already exists is used unchanged (e.g. the committed
# example's test IDs).
#
# CALLED ONCE PER APP FROM THE SEQUENTIAL LOOP BELOW — NEVER IN PARALLEL. Both
# this function's output path (Tuist/AdMob.xcconfig) and the `tuist generate`
# call right after it (Game.xcworkspace) are single, app-agnostic, repo-wide
# paths (Tuist project structure, not a choice this script makes). Running two
# apps' archive stages concurrently would race both files — worst case, one
# app's binary silently gets compiled with the OTHER app's AdMob ID. This is
# the reason <app> all keeps archive/export sequential and only parallelizes
# the upload step below (see the PIPELINE comment near the top of this file).
render_admob_xcconfig() {
    local env_file="$REPO_ROOT/secrets/.env"
    [[ -f "$env_file" ]] || return 0
    # shellcheck disable=SC1090
    source "$env_file"
    local prefix
    case "$APP" in
        sudoku)      prefix="SUDOKU" ;;
        minesweeper) prefix="MINESWEEPER" ;;
        *) return 0 ;;
    esac
    local app_id_var="${prefix}_ADMOB_APP_ID"
    local banner_var="${prefix}_ADMOB_BANNER_UNIT_ID"
    local app_id="${!app_id_var:-}"
    local banner="${!banner_var:-}"
    if [[ -z "$app_id" || -z "$banner" ]]; then
        echo "==> AdMob: ${app_id_var}/${banner_var} not in secrets/.env — keeping existing Tuist/AdMob.xcconfig as-is."
        return 0
    fi
    {
        echo "// Rendered by mise-tasks/tf/upload from secrets/.env (${prefix}_ADMOB_*)."
        echo "// Gitignored. Do not commit. See ci_post_clone.sh §3.1b for the XCC twin."
        echo "ADMOB_APP_ID = ${app_id}"
        echo "ADMOB_BANNER_UNIT_ID = ${banner}"
    } > "$REPO_ROOT/Tuist/AdMob.xcconfig"
    echo "==> AdMob: rendered Tuist/AdMob.xcconfig for $APP from secrets/.env (values not shown)."
}

# Credentials are needed for archive (DEVELOPMENT_TEAM) and upload, and are
# account-level (one ASC API key for both apps) — load once, before any app's
# archive stage, not per app.
load_asc_creds

# Clean up the staged key symlink on every exit path (staged once below, right
# before the parallel upload jobs start; this trap is what guarantees it is
# also removed once — not per finishing job — after the LAST job exits, since
# the trap only fires at overall script exit).
trap 'rm -f "$BUILD_DIR/private_keys/AuthKey_${ASC_KEY_ID:-X}.p8" 2>/dev/null || true' EXIT

# ── Sequential per-app archive+export stage (#670 PR2) ───────────────────────
# For <app> all this iterates sudoku THEN minesweeper, one fully at a time:
# admob-render → tuist install/generate → gen:acknowledgements → re-generate →
# archive → bump → export. See render_admob_xcconfig's comment above for why
# this must not be parallelized. Reassigns $APP/$SCHEME/$BUNDLE per iteration;
# after the loop these globals hold the LAST app processed, which is fine —
# nothing downstream (the parallel upload stage) reads them, it reads
# EXPORT_RECORDS instead.
EXPORT_RECORDS=()
US=$'\x1f'
for target_app in "${TARGET_APPS[@]}"; do
    APP="$target_app"
    SCHEME="$(scheme_for "$APP")"
    BUNDLE="$(bundle_for "$APP")"

    render_admob_xcconfig

    # Resolve packages + materialise the workspace. `tuist install` populates
    # the SwiftPM checkouts + Package.resolved that LicensePlist reads next;
    # `tuist generate` creates the *.xcworkspace (gitignored). Always run
    # install so the resolved state exists even when the workspace already
    # exists from a prior run.
    mise exec -- tuist install
    [[ -d "$WORKSPACE" ]] || {
        echo "==> $WORKSPACE not found — generating with tuist."
        mise exec -- tuist generate --no-open
    }
    [[ -d "$WORKSPACE" ]] || { echo "error: tuist generate did not produce $WORKSPACE" >&2; exit 1; }

    # Regenerate Acknowledgements Settings.bundle, then RE-generate the
    # project. The Settings.bundle is gitignored build output (Xcode Cloud
    # regenerates it via ci_post_clone.sh), so on a local machine it's absent
    # until we regenerate it here. Without it the installed build's iOS
    # Settings → Acknowledgements page is empty. Two ordering constraints,
    # both load-bearing:
    #
    #   1. gen must run AFTER `tuist install` — LicensePlist enumerates the
    #      dependency graph from the resolved SwiftPM state (Package.resolved
    #      + the package checkouts). Run it with no resolution in place and
    #      it emits an EMPTY list.
    #   2. gen must run BEFORE `tuist generate` *captures* the bundle — Tuist
    #      globs it as an App resource (Project.swift:
    #      `App/<App>/Resources/Settings.bundle/**`) and the glob is resolved
    #      into file references at generate time, not build time. If the
    #      bundle dir is absent/empty when the project is generated,
    #      xcodebuild copies nothing into the .app.
    #
    # So: install (resolve) → gen (populate bundle) → generate (re-glob the
    # now-populated bundle) → archive. The unconditional re-generate below is
    # what makes the freshly-written bundle land in the generated project's
    # resource phase — for THIS app, since gen:acknowledgements reads
    # App/<App>/license_plist.yml for the current $APP.
    echo "==> regenerate Acknowledgements Settings.bundle (gen:acknowledgements) — $APP"
    mise run gen:acknowledgements
    echo "==> re-generate project so Tuist globs the populated Settings.bundle — $APP"
    mise exec -- tuist generate --no-open

    case "$PLAT" in
        ios)   archive_export_platform ios ;;
        macos) archive_export_platform macos ;;
        all)   archive_export_platform ios; archive_export_platform macos ;;
    esac
done

if [[ "$ARCHIVE_ONLY" -eq 1 ]]; then
    echo "==> done (--archive-only: no upload)."
    exit 0
fi

if [[ ${#EXPORT_RECORDS[@]} -eq 0 ]]; then
    echo "error: no packages were exported to upload." >&2
    exit 1
fi

# ── Parallel upload stage (#670 PR2) ──────────────────────────────────────────
# Every EXPORT_RECORDS entry is a package that finished archiving+exporting
# sequentially above; the upload itself is network-bound and independent per
# app, so it fans out — one background `xcrun altool` job per package.
BUNDLES_LIST=""
for target_app in "${TARGET_APPS[@]}"; do
    BUNDLES_LIST="${BUNDLES_LIST:+$BUNDLES_LIST, }$(bundle_for "$target_app")"
done
echo "────────────────────────────────────────────────────────────────"
echo " TESTFLIGHT UPLOAD — ${#EXPORT_RECORDS[@]} package(s), build $BUILD_NUMBER"
echo "────────────────────────────────────────────────────────────────"
echo " This is a USER-OWNED, irreversible action. It signs with your"
echo " App Store distribution identity + provisioning profile and pushes"
echo " the build(s) to App Store Connect / TestFlight. Confirm the build"
echo " number is unique for: $BUNDLES_LIST @ this marketing version before"
echo " proceeding (duplicates are rejected by ASC). One --i-am-sure confirms"
echo " the WHOLE batch below, not each package individually."
echo "────────────────────────────────────────────────────────────────"
if [[ "$SURE" -ne 1 ]]; then
    echo "Refusing to upload without --i-am-sure. (Re-run with --archive-only to" >&2
    echo "just produce the package(s), or add --i-am-sure to upload.)" >&2
    exit 2
fi

# Key is staged ONCE for the whole batch (shared ASC API key, not per-app) —
# staging it per-job would re-create the same symlink harmlessly, but cleaning
# it up per-job (the old per-run `trap` behavior) is exactly the race #670
# called out: the first job to finish would delete the key out from under a
# sibling job still uploading. Cleanup instead happens once, after every job
# below has been `wait`ed, via the single EXIT trap set above.
stage_key_for_altool

UPLOAD_PIDS=()
for record in "${EXPORT_RECORDS[@]}"; do
    IFS="$US" read -r r_app r_plat r_pkg r_type <<<"$record"
    result_file="$BUILD_DIR/${r_app}-${r_plat}.upload_result"
    rm -f "$result_file"
    echo "==> altool --upload-app (type=$r_type) — $r_app $r_plat (background)"
    upload_one "$r_app" "$r_plat" "$r_pkg" "$r_type" "$result_file" &
    UPLOAD_PIDS+=("$!")
done

# `wait` on a job that exited non-zero would trip `set -e` and abort before
# every sibling has finished / before results are read — `|| true` per-pid
# neutralizes that; the REAL exit code was already written to each job's
# result file by upload_one, independent of `wait`'s return value here.
for pid in "${UPLOAD_PIDS[@]}"; do
    wait "$pid" || true
done

FAILED_APPS=()
for record in "${EXPORT_RECORDS[@]}"; do
    IFS="$US" read -r r_app r_plat r_pkg r_type <<<"$record"
    result_file="$BUILD_DIR/${r_app}-${r_plat}.upload_result"
    code="$(cat "$result_file" 2>/dev/null || echo 1)"
    rm -f "$result_file"
    if [[ "$code" == "0" ]]; then
        echo "==> uploaded $r_app $r_plat build $BUILD_NUMBER to TestFlight. Processing in ASC may take minutes."
        # changelog + tag (#694 P1), per successful app+plat. ORDER MATTERS:
        # the changelog must run BEFORE tagging this build — latest_tf_tag
        # would otherwise pick up the tag just created for THIS build (it
        # points at HEAD) and emit an empty HEAD..HEAD changelog. Both steps
        # are warn-only: the upload already succeeded, so neither a changelog
        # failure nor a tag/push failure may fail the task, and one app's
        # changelog/tag hiccup must never touch another app's.
        run_changelog "$r_app" "$r_plat" "$BUILD_NUMBER" \
            || echo "warning: changelog generation failed for a completed upload ($r_app $r_plat, upload already succeeded) — re-run with --changelog-only to regenerate manually." >&2
        create_and_push_tf_tag "$r_app" "$r_plat" "$BUILD_NUMBER"
    else
        echo "error: TestFlight upload FAILED for $r_app $r_plat (altool exit $code) — see the [${r_app}-${r_plat}] tagged output above." >&2
        FAILED_APPS+=("${r_app}/${r_plat}")
    fi
done

if [[ ${#FAILED_APPS[@]} -gt 0 ]]; then
    echo "────────────────────────────────────────────────────────────────" >&2
    echo " TestFlight upload FAILED for: ${FAILED_APPS[*]}" >&2
    echo " Any other app/platform in this invocation succeeded independently" >&2
    echo " (see the per-app '==> uploaded' / '==> tagged' lines above) and its" >&2
    echo " changelog + tag were already committed — re-run just the failed" >&2
    echo " app/platform to retry." >&2
    echo "────────────────────────────────────────────────────────────────" >&2
    exit 1
fi

echo "==> done."
