# ASCRegister CLI credentials — template.
#
# COPY this file to `secrets/.env` (gitignored) and fill in real values from
# the project's private memory `asc-api-credentials`. The real `.env` and
# the AuthKey .p8 file must NEVER be committed.
#
# On a fresh clone:
#   cp secrets/.env.example secrets/.env
#   # then edit secrets/.env with real values from memory `asc-api-credentials`
#   # then move the .p8 key file (see ASC_API_KEY_PATH below) from
#   #   ~/GitHub/ASCAPI_AuthKey_<KEY_ID>.p8  →  secrets/ASCAPI_AuthKey_<KEY_ID>.p8
#   #   chmod 600 secrets/ASCAPI_AuthKey_*.p8
#
# Usage with ASCRegister: source the env file once per shell, then invoke the
# CLI with the existing flags (the CLI does not read env vars directly; this
# file is just a convenience so you don't retype credentials each time):
#
#   source secrets/.env
#   swift run ASCRegister plan \
#     --key "$ASC_API_KEY_PATH" \
#     --key-id "$ASC_API_KEY_ID" \
#     --issuer "$ASC_API_ISSUER_ID" \
#     --app-id "$ASC_APP_ID_SUDOKU" \
#     --xcstrings Sudoku/Resources/Localizable.xcstrings
#
# All values below are placeholders. Replace with real values for local use.
# Apple's docs: https://developer.apple.com/documentation/appstoreconnectapi/creating-api-keys-for-app-store-connect-api

# Path to the ASC API .p8 private key file (chmod 600). Conventionally lives
# inside this same `secrets/` directory so the gitignore deny-by-default
# rule catches accidental `git add`s.
ASC_API_KEY_PATH=secrets/ASCAPI_AuthKey_REPLACE_KEY_ID.p8

# 10-character ASC API key ID (filename suffix of the .p8 file).
ASC_API_KEY_ID=REPLACE_KEY_ID

# ASC issuer UUID (Users and Access → Keys → top of the page).
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Per-app ASC App ID (numeric, from ASC URL https://appstoreconnect.apple.com/apps/<id>/...).
ASC_APP_ID_SUDOKU=0000000000
ASC_APP_ID_MINESWEEPER=0000000000

# ── Local TestFlight upload tool (`mise run tf:upload …`, foundations.md §4) ──
# The tf:upload task (temporary Xcode-Cloud substitute) REUSES the three ASC_API_*
# keys above (key path / key id / issuer) for `xcrun altool --upload-app`, and
# reuses CK_TEAM_ID below for the archive's DEVELOPMENT_TEAM + the generated
# ExportOptions.plist teamID. No new keys are required.

# ── CloudKit schema tooling (`mise run ck:schema …`, GitHub issue #337) ───────
# Used by mise-tasks/ck/schema to export the Dev schema and (user-owned) deploy
# it to Production via `xcrun cktool`. See docs/foundations.md §7.7.2.
#
# CloudKit *management* token — generate ONCE in CloudKit Dashboard → Settings →
# Tokens → "Create Token" (Management). This is the cktool equivalent of the ASC
# .p8 key. It is a long opaque secret: NEVER commit it, NEVER print it.
CK_MANAGEMENT_TOKEN=replace-with-cloudkit-management-token

# 10-character Apple Developer Team ID (same value as Tuist/Signing.xcconfig
# DEVELOPMENT_TEAM). Required by cktool's --team-id flag.
CK_TEAM_ID=REPLACE_TEAM_ID

# AdMob production IDs (per-app). Consumed by mise-tasks/tf/upload's
# render_admob_xcconfig (local twin of ci_post_clone.sh §3.1b). Values live in
# the real secrets/.env only — never committed. Debug builds force Google's
# test ad unit in code regardless.
SUDOKU_ADMOB_APP_ID=ca-app-pub-REPLACE~REPLACE
SUDOKU_ADMOB_BANNER_UNIT_ID=ca-app-pub-REPLACE/REPLACE
MINESWEEPER_ADMOB_APP_ID=ca-app-pub-REPLACE~REPLACE
MINESWEEPER_ADMOB_BANNER_UNIT_ID=ca-app-pub-REPLACE/REPLACE
